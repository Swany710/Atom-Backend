# ─────────────────────────────────────────────────────────────────────────────
# Atom Backend — Environment Variable Template
# Copy this to .env and fill in every value.
# In production set these in Railway — never commit .env
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Authentication ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=
JWT_SECRET=
JWT_EXPIRES_IN=7d
OWNER_USER_ID=

# ── Supabase / Database ───────────────────────────────────────────────────────
#
# Project ref: jxmrhqmimhncmuruioiz
# Project URL: https://jxmrhqmimhncmuruioiz.supabase.co
#
# TWO connection string options — use Transaction Pooler for Railway (recommended):
#
# Option A — Transaction Pooler (port 6543) ← USE THIS FOR RAILWAY
#   Handles connection spikes, no persistent connections needed.
#   Does NOT support prepared statements (handled automatically).
#   DATABASE_URL=postgresql://postgres.jxmrhqmimhncmuruioiz:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Option B — Direct Connection (port 5432) ← use for local dev / migrations
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.jxmrhqmimhncmuruioiz.supabase.co:5432/postgres
#
DATABASE_URL=postgresql://postgres.jxmrhqmimhncmuruioiz:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# SSL — Supabase always requires SSL; strict cert validation optional
DATABASE_SSL=true
DATABASE_TLS_STRICT=false

# Supabase API keys (from Settings → API in Supabase dashboard)
SUPABASE_URL=https://jxmrhqmimhncmuruioiz.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp4bXJocW1pbWhuY211cnVpb2l6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIyMDc1MjYsImV4cCI6MjA4Nzc4MzUyNn0.u0fKRn702kyvIgMiw0V2zQJyojR0HQyjC9kZ_8ZuFA8
# SUPABASE_SERVICE_ROLE_KEY= ← set in Railway only, never commit

# ── Token encryption ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
OAUTH_STATE_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/integrations/calendar/oauth/callback

# ── Microsoft OAuth ───────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/integrations/email/outlook/callback

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email provider ────────────────────────────────────────────────────────────
EMAIL_PROVIDER=gmail

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8081
