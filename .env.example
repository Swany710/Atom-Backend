# ─────────────────────────────────────────────────────────────────────────────
# Atom Backend — Environment Variable Template
# Copy this file to .env and fill in every value before running locally.
# In production (Railway), set these in the Railway dashboard — never commit .env
#
# REQUIRED IN PRODUCTION — validateProductionEnv() will exit(1) if any are missing
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Comma-separated list of allowed CORS origins. Wildcards are rejected in prod.
# Example: https://dasho.app,https://www.mcgeerestoration.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Authentication ────────────────────────────────────────────────────────────
# Bearer token for service-to-service / legacy single-owner auth.
# Must be ≥ 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# JWT signing secret for per-user auth. Must be ≥ 32 characters.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# UUID of the "owner" user — used when auth mode is API-key (not JWT).
# Find this in the users table after your first registration.
OWNER_USER_ID=

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Full Postgres connection URL from the Supabase dashboard.
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Set to true to enforce TLS certificate validation (recommended in production).
DATABASE_TLS_STRICT=false

# Optional — used by services that call Supabase APIs directly (not TypeORM).
SUPABASE_URL=
SUPABASE_KEY=

# ── Token encryption (OAuth tokens stored at rest) ────────────────────────────
# Must be exactly 64 hexadecimal characters (32 bytes for AES-256-GCM).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Secret for signing OAuth state parameters. Must be ≥ 32 characters.
OAUTH_STATE_SECRET=

# ── Google OAuth (Calendar + Gmail) ──────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/integrations/calendar/oauth/callback

# ── Microsoft OAuth (Outlook / Graph API) ────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/integrations/email/outlook/callback

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Used for GPT-4o-mini (text/tool calls) and Whisper-1 (voice transcription).
OPENAI_API_KEY=

# ── Email provider ────────────────────────────────────────────────────────────
# Set to 'gmail' or 'outlook'
EMAIL_PROVIDER=gmail

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8081
