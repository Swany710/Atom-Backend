# ─────────────────────────────────────────────────────────────────────────────
# Atom Backend — Environment Variable Template
# Copy this to .env and fill in every value.
# In production set these in Railway — never commit .env
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Authentication ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=
JWT_SECRET=
# Token lifetime — default 24h. Tokens live in browser localStorage, so keep short.
JWT_EXPIRES_IN=24h
OWNER_USER_ID=

# ── Supabase / Database ───────────────────────────────────────────────────────
#
# Find your project ref and URL in: Supabase Dashboard → Settings → API
#
# TWO connection string options — use Transaction Pooler for Railway (recommended):
#
# Option A — Transaction Pooler (port 6543) ← USE THIS FOR RAILWAY
#   Handles connection spikes, no persistent connections needed.
#   Does NOT support prepared statements (handled automatically).
#   Copy the Transaction pooler string from Supabase Dashboard -> Connect.
#   The pooler host is region-specific; do not leave aws-0-us-east-1 unless
#   Supabase gave you that exact host.
#   DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres
#
# Option B — Direct Connection (port 5432) ← use for local dev / migrations
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres

# SSL — Supabase always requires SSL.
# DATABASE_TLS_STRICT=true verifies the server certificate (recommended in
# production — protects DB traffic from man-in-the-middle attacks).
# Supabase uses its own CA, so strict mode needs the CA cert. Download it from
# Supabase Dashboard → Settings → Database → SSL, then set ONE of:
#   DATABASE_CA_CERT       — paste the full PEM contents (Railway-friendly)
#   DATABASE_CA_CERT_PATH  — path to the .crt/.pem file on disk
DATABASE_SSL=true
DATABASE_TLS_STRICT=true
DATABASE_CA_CERT=
# supabase-prod-ca.crt is committed at the repo root (Supabase Intermediate +
# Root 2021 CA, extracted from the live pooler TLS handshake — public cert).
DATABASE_CA_CERT_PATH=supabase-prod-ca.crt

# Supabase API keys (from Settings → API in Supabase dashboard)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
# SUPABASE_SERVICE_ROLE_KEY= ← set in Railway only, never commit

# ── Token encryption ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
OAUTH_STATE_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/integrations/calendar/oauth/callback

# ── Microsoft OAuth ───────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/integrations/email/outlook/callback

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Model used by the orchestrator (optional — defaults to claude-sonnet-4-5-20250929)
CLAUDE_MODEL=

# ── Email provider ────────────────────────────────────────────────────────────
EMAIL_PROVIDER=gmail

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8081
